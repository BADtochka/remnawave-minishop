IMAGE_TAG=latest
MINIAPP_PUBLIC_URL=https://app.example.com/
FRONTEND_BIND=127.0.0.1:8082

# Browser requests stay same-origin to https://app.example.com/api.
WEBAPP_API_BASE_URL=/api

# One backend-domain mode: backend reverse proxy routes /api, /auth, /open-app,
# and Web App assets to backend:8081 and injects/checks the edge token.
WEBAPP_BACKEND_UPSTREAM=https://bot.example.com
WEBAPP_BACKEND_UPSTREAM_HOST=bot.example.com
MINISHOP_EDGE_TOKEN=change_me_same_value_as_backend
MINISHOP_EDGE_TOKEN_HEADER=X-Minishop-Edge-Token

