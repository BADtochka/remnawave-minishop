{
  "module_size": {
    "max_lines": 1000,
    "scopes": [
      "backend/bot",
      "backend/config",
      "backend/db",
      "frontend/src"
    ],
    "extensions": [
      ".py",
      ".ts",
      ".svelte",
      ".js"
    ],
    "allowlist": [
      "backend/bot/app/web/templates/*.js",
      "backend/db/migrator.py",
      "frontend/src/lib/api/openapi.generated.ts",
      "frontend/src/lib/webapp/demoDataset.js",
      "frontend/src/lib/webapp/mockApi.js",
      "frontend/src/lib/webapp/previewMock.js"
    ]
  },
  "type_ignore": {
    "scopes": [
      "backend/bot",
      "backend/config"
    ],
    "allowlist": {
      "backend/config/settings.py": 1,
      "backend/config/webapp_themes_config.py": 1,
      "backend/bot/app/controllers/dispatcher_controller.py": 1,
      "backend/bot/services/panel_api_service.py": 1
    }
  },
  "raw_json_response": {
    "scopes": [
      "backend/bot/app/web/admin_api_impl",
      "backend/bot/app/web/webapp"
    ],
    "allowlist": [
      "backend/bot/app/web/response_helpers.py",
      "backend/bot/app/web/webapp/response_helpers.py"
    ]
  },
  "loose_schemas": {
    "scopes": [
      "backend/bot/app/web/admin_api_impl",
      "backend/bot/app/web/webapp"
    ],
    "allowlist": {}
  },
  "frontend_weak_typing": {
    "scopes": [
      "frontend/src"
    ],
    "extensions": [
      ".ts",
      ".js",
      ".svelte"
    ],
    "allowlist": [],
    "allowed_counts": {}
  },
  "svelte_lang_ts": {
    "scopes": [
      "frontend/src"
    ],
    "allowlist": [
      "frontend/src/PreviewBoard.svelte",
      "frontend/src/lib/components/patterns/admin/AdminBadge.svelte",
      "frontend/src/lib/components/patterns/admin/AdminButton.svelte",
      "frontend/src/lib/components/patterns/admin/AdminDashboardGrid.svelte",
      "frontend/src/lib/components/patterns/admin/AdminDashboardStack.svelte",
      "frontend/src/lib/components/patterns/admin/AdminEmptyState.svelte",
      "frontend/src/lib/components/patterns/admin/AdminField.svelte",
      "frontend/src/lib/components/patterns/admin/AdminRevenueChart.svelte",
      "frontend/src/lib/components/patterns/admin/AdminRevenueCustomRangePopover.svelte",
      "frontend/src/lib/components/patterns/admin/AdminSectionHeader.svelte",
      "frontend/src/lib/components/patterns/admin/AdminSelect.svelte",
      "frontend/src/lib/components/patterns/admin/AdminTable.svelte",
      "frontend/src/lib/components/patterns/admin/AdminTableSkeleton.svelte",
      "frontend/src/lib/components/patterns/admin/AdminTrafficCard.svelte",
      "frontend/src/lib/components/patterns/admin/SupportComposer.svelte",
      "frontend/src/lib/components/patterns/admin/SupportInboxRow.svelte",
      "frontend/src/lib/components/patterns/admin/SupportTicketHeader.svelte",
      "frontend/src/lib/components/patterns/admin/SupportUserContextPanel.svelte",
      "frontend/src/lib/components/patterns/webapp/DialogOptionsSkeleton.svelte",
      "frontend/src/lib/components/patterns/webapp/TicketMessageBubble.svelte",
      "frontend/src/lib/webapp/BrandMark.svelte",
      "frontend/src/preview/BackTitle.svelte",
      "frontend/src/preview/PhoneFrame.svelte",
      "frontend/src/preview/PreviewMethods.svelte",
      "frontend/src/preview/PreviewNav.svelte",
      "frontend/src/webapp/TelegramNotificationsBanner.svelte"
    ]
  },
  "frontend_api_calls": {
    "scopes": [
      "frontend/src"
    ],
    "allowed_calls": [
      "apiUnchecked"
    ],
    "allowlist_paths": []
  },
  "runtime_all_exports": {
    "paths": [
      "backend/bot/app/web/admin_api_impl/_runtime.py",
      "backend/bot/app/web/webapp/_runtime.py",
      "backend/bot/services/subscription_service_impl/_runtime.py"
    ]
  },
  "runtime_imports": {
    "scopes": [
      "backend"
    ],
    "runtime_modules": {
      "admin_api_impl_runtime": "bot.app.web.admin_api_impl._runtime",
      "webapp_runtime": "bot.app.web.webapp._runtime",
      "subscription_service_impl_runtime": "bot.services.subscription_service_impl._runtime"
    },
    "baseline_path": "scripts/runtime_import_baseline.json",
    "allowlist_paths": []
  },
  "facade_imports": {
    "scopes": [
      "backend"
    ],
    "facades": {
      "admin_api": "bot.app.web.admin_api",
      "subscription_webapp": "bot.app.web.subscription_webapp",
      "subscription_service": "bot.services.subscription_service"
    },
    "allowed_importers": {
      "admin_api": [
        "backend/bot/app/web/admin_api.py",
        "backend/bot/app/web/web_server.py"
      ],
      "subscription_webapp": [
        "backend/bot/app/web/subscription_webapp.py",
        "backend/bot/app/web/web_server.py"
      ],
      "subscription_service": []
    },
    "allowlist_paths": []
  },
  "route_contracts": {
    "route_setup_scopes": [
      "backend/bot/app/web/admin_api_impl/routes.py",
      "backend/bot/app/web/webapp/routes.py"
    ],
    "contract_scopes": [
      "backend/bot/app/web/admin_api_impl",
      "backend/bot/app/web/webapp"
    ],
    "path_allowlist": [
      "/api/admin/payments/export.csv"
    ]
  }
}
